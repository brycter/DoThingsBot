<?xml version="1.0"?>
<view icon="0" title="Decal Plugin" width="500" height="415">
		<control progid="DecalControls.Notebook" name="UIStatsMainTabs">
		<page label="Session Stats">
			<control progid="DecalControls.FixedLayout" clipped="">
        <control progid="DecalControls.PushButton" name="UIStatsEchoSessionStats" left="320" top="4" width="120" height="19" text="Echo to Chat Window"/>
        <control progid="DecalControls.FixedLayout" clipped="" left="0" top="0" width="1200" height="310" name="UIStatsSessionStatsLayout">
        </control>
			</control>

		</page>
		<page label="Global Stats">
			<control progid="DecalControls.FixedLayout" clipped="">
        <control progid="DecalControls.PushButton" name="UIStatsEchoGlobalStats" left="372" top="350" width="120" height="20" text="Echo to Chat Window"/>
