        <control progid="DecalControls.PushButton" name="UIStatsEchoCharacterStats" left="320" top="4" width="120" height="19" text="Echo to Chat Window"/>

          <control progid="DecalControls.FixedLayout" clipped="" left="0" top="0" width="1200" height="310" name="UIStatsCharacterStatsLayout">
				</control>

			</control>

		</page>
		</control>

</view>
